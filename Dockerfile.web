# ============================================================================
# A股数据仓库 — Web 控制面板
# ============================================================================
FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Install the package
COPY pyproject.toml ./
COPY src/ ./src/
COPY config.yaml ./
RUN pip install --no-cache-dir .

EXPOSE 5000

CMD ["ingestion", "serve", "--host", "0.0.0.0", "--port", "5000"]
