# ============================================================================
# A股数据仓库 — MCP Server (HTTP/SSE)
# 轻量镜像：仅 MCP 需要的依赖，不含 akshare/baostock/opentdx 等重型包
# ============================================================================
FROM python:3.12-slim

WORKDIR /app

# MCP 只读 DuckDB，不需要 akshare/baostock/opentdx
RUN pip install --no-cache-dir \
    duckdb>=1.1.0 \
    pandas>=2.0.0 \
    pyarrow>=17.0.0 \
    pyyaml>=6.0 \
    python-dotenv>=1.0.0 \
    mcp>=1.0.0 \
    uvicorn>=0.30.0

# 安装项目包（跳过声明依赖，因为核心依赖已在上方装好）
COPY pyproject.toml ./
COPY src/ ./src/
RUN pip install --no-cache-dir --no-deps .

EXPOSE 8000

CMD ["python", "-m", "src.ingestion.mcp_server"]
