# ============================================================================
# A股数据仓库 — MCP Server (HTTP/SSE)
# DataService: easy_tdx 实时行情, httpx 新闻/快讯
# ============================================================================
FROM python:3.12-slim

WORKDIR /app

# MCP + 数据访问依赖
RUN pip install --no-cache-dir \
    duckdb>=1.1.0 \
    pandas>=2.0.0 \
    pyarrow>=17.0.0 \
    pyyaml>=6.0 \
    python-dotenv>=1.0.0 \
    mcp>=1.0.0 \
    uvicorn>=0.30.0 \
    httpx>=0.27.0 \
    beautifulsoup4>=4.12.0 \
    easy_tdx>=1.4.0 \
    akshare>=1.12.0

# 安装项目包（跳过声明依赖）
COPY pyproject.toml ./
COPY src/ ./src/
RUN pip install --no-cache-dir --no-deps .

# Persist easy_tdx cache across restarts
RUN mkdir -p /app/data/.easy_tdx/cache \
    && ln -sf /app/data/.easy_tdx /root/.easy_tdx

EXPOSE 8000

CMD ["python", "-m", "src.ingestion.mcp_server"]
